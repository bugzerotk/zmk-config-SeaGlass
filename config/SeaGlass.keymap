// #include <layout_shift.dtsi>
#include <behaviors/runtime-sensor-rotate.dtsi>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

#undef ZMK_POINTING_DEFAULT_SCRL_VAL

#define ZMK_POINTING_DEFAULT_SCRL_VAL 120

// Keymap Editor を使用すると include <layout_shift_kp_override.dtsi> が一番上に移動するため
// layout_shift_kp_override.dtsi の内容を直接記載

// / {
//     behaviors {
//         // Keep the original key_press behavior for ZMK core components
// 
//         original_key_press: original_key_press {
//             compatible = "zmk,behavior-key-press";
//             #binding-cells = <1>;
//             label = "KEY_PRESS";
//         };
// 
//         // Override the existing &kp behavior to use our custom implementation
// 
//         kp: key_press {
//             compatible = "zmk,behavior-layout-shift-key-press";
//             #binding-cells = <1>;
//             label = "LAYOUT_SHIFT_KEY_PRESS";
//         };
//     };
// };

&mt {
    flavor = "balanced";
    quick-tap-ms = <300>;
};

&lt {
    flavor = "balanced";
    quick-tap-ms = <300>;
};

/ {
    combos {
        compatible = "zmk,combos";

        middle-click {
            bindings = <&mkp MB3>;
            key-positions = <40 41>;
        };

        open-square-bracket {
            bindings = <&kp LEFT_BRACKET>;
            key-positions = <16 17>;
            layers = <0>;
        };

        close-square-bracket {
            bindings = <&kp RIGHT_BRACKET>;
            key-positions = <17 18>;
            layers = <0>;
        };

        open-brace {
            bindings = <&kp LEFT_BRACE>;
            key-positions = <26 27>;
            layers = <0>;
        };

        close-brace {
            bindings = <&kp RIGHT_BRACE>;
            key-positions = <27 28>;
            layers = <0>;
        };

        parentheses {
            bindings = <&kakko>;
            key-positions = <6 8>;
            layers = <0>;
        };

        square-brackets {
            bindings = <&dai_kakkko>;
            key-positions = <16 18>;
            layers = <0>;
        };

        curly-brackets {
            bindings = <&nami_kakko>;
            key-positions = <26 28>;
        };
    };

    macros {
        to_layer_0: to_layer_0 {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings = <&to 0 &macro_param_1to1 &kp MACRO_PLACEHOLDER>;
            label = "TO_LAYER_0";
        };

        kakko: kakko {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LEFT_PARENTHESIS &kp RIGHT_PARENTHESIS &kp LEFT_ARROW>;
            label = "KAKKO";
        };

        dai_kakkko: daikakkko {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LEFT_BRACKET &kp RIGHT_BRACKET &kp LEFT_ARROW>;
            label = "DAIKAKKKO";
        };

        nami_kakko: nami_kakko {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LEFT_BRACE &kp RIGHT_BRACE &kp LEFT_ARROW>;
            label = "NAMI_KAKKO";
        };
    };

    behaviors {
        lt_to_layer_0: lt_to_layer_0 {
            compatible = "zmk,behavior-hold-tap";
            label = "LAYER_TAP_TO_0";
            bindings = <&mo>, <&to_layer_0>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
        };

        rsr_scroll_ud: rsr_scroll_ud {
            compatible = "zmk,behavior-runtime-sensor-rotate";
            #sensor-binding-cells = <0>;
            tap-ms = <20>;
            cw-binding = <&msc SCRL_UP>;
            ccw-binding = <&msc SCRL_DOWN>;
        };

        rsr_scroll_lr: rsr_scroll_lr {
            compatible = "zmk,behavior-runtime-sensor-rotate";
            #sensor-binding-cells = <0>;
            tap-ms = <20>;
            cw-binding = <&msc SCRL_LEFT>;
            ccw-binding = <&msc SCRL_RIGHT>;
        };

        lt_hp: lt_hp {
            compatible = "zmk,behavior-hold-tap";
            label = "LT_HP";
            bindings = <&mo>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <300>;
        };

        mt_hp: mt_hp {
            compatible = "zmk,behavior-hold-tap";
            label = "MT_HP";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <300>;
        };

        tl_tp: tl_tp {
            compatible = "zmk,behavior-hold-tap";
            label = "TL_TP";
            bindings = <&mo>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <300>;
            flavor = "tap-preferred";
        };

        td_lalt_win: td_lalt_win {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_LALT_WIN";
            #binding-cells = <0>;
            bindings = <&mt_hp LEFT_ALT LEFT_ALT>, <&kp LEFT_WIN>;
        };

        td_dot_alt_win: td_dot_alt_win {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_DOT_ALT_WIN";
            #binding-cells = <0>;
            bindings = <&mt_hp LEFT_ALT PERIOD>, <&kp LEFT_WIN>;
        };

        td_x_alt_win: td_x_alt_win {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_X_ALT_WIN";
            #binding-cells = <0>;
            bindings = <&mt_hp LEFT_ALT X>, <&kp LEFT_WIN>;
        };

        td_ralt_win: td_ralt_win {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_RALT_WIN";
            #binding-cells = <0>;
            bindings = <&mt_hp RIGHT_ALT RIGHT_ALT>, <&kp LEFT_WIN>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&lt 5 Q           &kp W      &kp E         &kp R             &lt 2 T      &lt 5 Y          &kp U                  &kp I        &kp O       &lt 7 P
&kp A             &kp S      &kp D         &kp F             &kp G        &kp H            &kp J                  &kp K        &kp L       &kp ENTER
&mt LEFT_SHIFT Z  &kp X      &kp C         &kp V             &kp B        &kp N            &kp M                  &kp COMMA    &kp PERIOD  &mt RIGHT_SHIFT MINUS
&kp GLOBE         &kp LCTRL  &kp LEFT_ALT  &mt LEFT_WIN TAB  &lt 1 SPACE  &lt 3 BACKSPACE  &mt RIGHT_SHIFT SLASH  &lt 6 ENTER  &trans      &lt 7 GLOBE
                                                                          &mkp MB1         &mkp MB2
            >;

            sensor-bindings = <&rsr_scroll_ud &rsr_scroll_lr>;
        };

        SYMBOL {
            bindings = <
&kp PRCNT  &kp DOLLAR  &kp AMPERSAND  &kp CARET        &kp FSLH      &kp BSLH        &kp LEFT_BRACE        &kp RIGHT_BRACE        &kp LESS_THAN  &kp GREATER_THAN
&kp AT     &kp HASH    &kp ASTERISK   &kp PLUS         &kp EQUAL     &kp UNDERSCORE  &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &kp SEMI       &kp COLON
&kp GRAVE  &kp TILDE   &kp MINUS      &kp EXCLAMATION  &kp QUESTION  &kp PIPE        &kp LBKT              &kp RBKT               &kp SQT        &kp DOUBLE_QUOTES
&trans     &trans      &trans         &trans           &trans        &kp BACKSPACE   &kp COMMA             &kp PERIOD             &kp ESC        &lt 5 ENTER
                                                                     &mkp MB1        &mkp MB2
            >;
        };

        NUM {
            bindings = <
&kp F11  &kp F12  &trans  &trans  &trans   &kp N7         &kp NUMBER_8  &kp NUMBER_9  &kp PLUS         &kp MINUS
&kp F6   &kp F7   &kp F8  &kp F9  &kp F10  &kp NUMBER_4   &kp NUMBER_5  &kp NUMBER_6  &kp ASTERISK     &kp SLASH
&kp F1   &kp F2   &kp F3  &kp F4  &kp F5   &kp NUMBER_1   &kp NUMBER_2  &kp NUMBER_3  &kp RIGHT_BRACE  &kp COLON
&trans   &trans   &trans  &trans  &trans   &kp BACKSPACE  &kp NUMBER_0  &kp PERIOD    &trans           &trans
                                           &mkp MB1       &mkp MB2
            >;
        };

        ARROW {
            bindings = <
&trans                      &mkp MB4                &kp LG(LA(UP_ARROW))  &mkp MB5                 &trans                       &kp LG(LEFT_ARROW)  &kp LA(LEFT_ARROW)  &kp UP_ARROW    &kp RA(RIGHT_ARROW)  &kp RG(RIGHT_ARROW)
&kp LA(LG(LC(LEFT_ARROW)))  &kp LA(LG(LEFT_ARROW))  &kp LA(LG(F))         &kp RG(RA(RIGHT_ARROW))  &kp RA(RC(RG(RIGHT_ARROW)))  &kp LC(LS(TAB))     &kp LEFT_ARROW      &kp DOWN_ARROW  &kp RIGHT_ARROW      &kp RC(TAB)
&trans                      &kp LG(LS(LEFT_ARROW))  &kp LG(LA(DOWN))      &kp LG(LS(RIGHT_ARROW))  &trans                       &trans              &trans              &trans          &trans               &trans
&trans                      &trans                  &trans                &trans                   &trans                       &trans              &trans              &kp BACKSPACE   &trans               &trans
                                                                                                                                &mkp MB1            &mkp MB2
            >;
        };

        MOUSE {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans    &trans    &trans    &trans    &trans
&trans  &trans  &trans  &trans  &trans  &trans    &mkp MB1  &mkp MB3  &mkp MB2  &trans
&trans  &trans  &trans  &trans  &trans  &trans    &trans    &trans    &trans    &trans
&trans  &trans  &trans  &trans  &trans  &trans    &trans    &trans    &trans    &trans
                                        &mkp MB1  &mkp MB2
            >;
        };

        SHORTCUT {
            bindings = <
&trans  &trans  &kp ENTER  &trans          &trans          &trans              &trans            &trans  &trans  &trans
&trans  &trans  &kp ENTER  &trans          &trans          &trans              &trans            &trans  &trans  &trans
&trans  &trans  &trans     &trans          &trans          &trans              &trans            &trans  &trans  &trans
&trans  &trans  &trans     &kp LS(LG(N5))  &kp LS(LG(N4))  &kp LC(DOWN_ARROW)  &kp LC(UP_ARROW)  &trans  &trans  &trans
                                                           &mkp MB1            &mkp MB2
            >;
        };

        CONFIG {
            bindings = <
&bt BT_CLR_ALL  &bt BT_CLR    &trans        &trans        &trans        &trans       &trans          &trans  &trans  &trans
&trans          &trans        &trans        &trans        &trans        &trans       &trans          &trans  &trans  &trans
&trans          &trans        &trans        &trans        &trans        &trans       &trans          &trans  &trans  &trans
&bt BT_SEL 0    &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &bootloader  &studio_unlock  &trans  &trans  &trans
                                                                        &kp LANG2    &kp LANG1
            >;
        };

        SCROLL {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
                                        &trans  &trans
            >;
        };
    };
};
